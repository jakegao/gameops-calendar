# ============================================
# GameOps Calendar — .gitignore
# ============================================

# === 依赖 ===
node_modules/
**/node_modules/

# === 构建产物 ===
dist/
dist-ssr/
build/
*.local

# === 环境变量 / 机密文件 ===
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# === 日志 ===
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# === OS 生成文件 ===
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# === 编辑器 / IDE ===
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# === CodeBuddy 内部数据 ===
.codebuddy/

# === 生成的图片（AI生成，不需要版本控制） ===
generated-images/

# === 锁文件（根目录的，子项目保留自己的） ===
/package-lock.json

# === 临时文件 ===
*.tmp
*.temp
*.bak
*.cache
.turbo/
